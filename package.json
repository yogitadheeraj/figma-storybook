{
  "name": "figma-storybook-autosync-enterprise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "sync:figma": "tsx scripts/sync-figma.ts",
    "generate:stories": "tsx scripts/generate-stories.ts",
    "enterprise:sync": "npm run sync:figma && npm run generate:stories",
    "webhook": "tsx server/webhook-server.ts",
    "webhook:debug": "DEBUG_API=true node --inspect=9229 --import tsx server/webhook-server.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "8.6.18",
    "tsx": "^4.19.2",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "chromatic": "^16.9.1",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
